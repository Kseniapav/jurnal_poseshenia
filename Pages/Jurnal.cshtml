@page
@model jurnal_poseshenia.Pages.JurnalsModel
@{
}

<form method="post" class="needs-validation" novalidate>
    <input type="hidden" asp-for="Jurnal.Id" />

    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label">Студент</label>
            <select class="form-select" asp-for="Jurnal.StudentId" asp-items="Model.StudentList">
                <option value="">Выберите студента 👉</option>
            </select>
            <span asp-validation-for="Jurnal.StudentId" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label class="form-label">Специальность</label>
            <select class="form-select" asp-for="Jurnal.Specialty">
                <option value="IT">IT</option>
                <option value="Logistician">Логист</option>
                <option value="Commodity specialist">Товаровед</option>
                <option value="Lawyer">Юрист</option>
                <option value="Electrician">Электрик</option>
                <option value="Accountant">Бухгалтер</option>
            </select>
        </div>

        <div class="col-md-6 mb-3">
            <label asp-for="Jurnal.VisitDate" class="form-label"></label>
            <input asp-for="Jurnal.VisitDate" class="form-control" type="date" />
            <span asp-validation-for="Jurnal.VisitDate" class="text-danger"></span>
        </div>
    </div>

    <div class="d-flex gap-2 justify-content-center mt-4">
        <button type="submit" class="btn btn-success px-4">Сохранить</button>
        <a asp-page="/Students" class="btn btn-outline-secondary px-4">Отмена</a>
    </div>
</form>