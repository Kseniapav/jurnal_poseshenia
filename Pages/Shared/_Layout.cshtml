<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Salfetka5</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Salfetka5.styles.css" asp-append-version="true" />
    <style>
        body {
            background-color: #121212;
            color: white;
        }

        .navbar {
            background-color: #1e1e1e;
            padding: 0.5rem 0;
        }

        .navbar-brand {
            font-size: 1.5rem;
            color: white !important;
            text-decoration: none;
            pointer-events: none;
            margin-right: 2rem;
            transition: transform 0.3s ease;
        }

            .navbar-brand:hover {
                transform: scale(1.05);
            }

        .nav-item {
            display: flex;
            align-items: center;
        }

        .nav-link {
            color: white !important;
            padding: 0.5rem 1rem;
            transition: all 0.3s ease;
            transform-origin: center;
            display: inline-block;
        }

            .nav-link:hover {
                color: lightblue !important;
                background-color: #333;
                border-radius: 4px;
                transform: scale(1.08);
            }

        /* Черточка между пунктами */
        .nav-divider {
            color: #666;
            padding: 0 0.2rem;
            user-select: none;
            transition: transform 0.3s ease;
        }

        .nav-item:hover .nav-divider {
            transform: scale(1.1);
        }

        footer {
            background-color: #1e1e1e;
            color: white;
        }

            footer a {
                color: lightskyblue;
            }

                footer a:hover {
                    color: deepskyblue;
                }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light border-bottom box-shadow mb-3">
            <div class="container">
                <span class="navbar-brand">Salfetka5💗</span>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1" style="display: flex; align-items: center;">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Index">Домашняя</a>
                        </li>
                        <span class="nav-divider">|</span>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Students">Студенты</a>
                        </li>
                        <span class="nav-divider">|</span>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Jurnals">Журнал</a>
                        </li>
                        <span class="nav-divider">|</span>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Privacy">Политика приватности</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2025 - Salfetka5 - <a asp-area="" asp-page="/Privacy">Политика приватности</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>